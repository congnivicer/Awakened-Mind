# NHB Knowledge Infrastructure - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ========================================
# SECURITY & AUTHENTICATION
# ========================================

# JWT Configuration (CRITICAL - Generate a strong secret key)
JWT_SECRET=your-super-secure-jwt-secret-here-minimum-32-characters-long
JWT_EXPIRES_IN=24h

# Session Configuration
SESSION_SECRET=another-secure-random-string-for-sessions

# ========================================
# API KEYS & EXTERNAL SERVICES
# ========================================

# GitHub API Token (move from config files)
GITHUB_TOKEN=your-github-personal-access-token-here

# Supabase Configuration (move from cloud_accounts.json)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Zilliz Cloud Configuration (move from cloud_accounts.json)
ZILLIZ_CLOUD_URI=https://your-zilliz-cloud-endpoint
ZILLIZ_CLOUD_API_KEY=your-zilliz-api-key-here

# Google Gemini API (move from cloud_accounts.json)
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# DATABASE & STORAGE
# ========================================

# ChromaDB Configuration (move from system_config.json)
CHROMA_DB_PATH=/Volumes/Knowledge/chroma
CHROMA_PERSIST_DIRECTORY=/Volumes/Knowledge/persistence

# Local Cache Configuration
LOCAL_CACHE_PATH=./cache/local_vectors
NAVIGATION_DB_PATH=./cache/knowledge_map.db

# ========================================
# APPLICATION SETTINGS
# ========================================

# Environment
NODE_ENV=development

# Server Configuration
PORT=3001
HOST=localhost

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/nhb_api.log

# ========================================
# PERFORMANCE & SCALING
# ========================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Connection Pooling
DB_CONNECTION_POOL_MIN=2
DB_CONNECTION_POOL_MAX=10

# Caching
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=100

# ========================================
# DEVELOPMENT SETTINGS
# ========================================

# Enable debug mode (development only)
DEBUG=false

# Enable detailed error reporting (development only)
VERBOSE_ERRORS=false

# ========================================
# PRODUCTION SETTINGS
# ========================================

# Trust proxy (set to true in production behind load balancer)
TRUST_PROXY=false

# HTTPS Configuration
SSL_KEY_PATH=/path/to/ssl/private.key
SSL_CERT_PATH=/path/to/ssl/certificate.crt

# ========================================
# MONITORING & OBSERVABILITY
# ========================================

# Application Monitoring
MONITORING_ENABLED=false
METRICS_PORT=9090

# Health Check Configuration
HEALTH_CHECK_INTERVAL_SECONDS=30

# ========================================
# BACKUP & RECOVERY
# ========================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/Volumes/Backup

# ========================================
# SECURITY HEADERS
# ========================================

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'

# ========================================
# FEATURE FLAGS
# ========================================

# Enable/disable specific features
FEATURE_GITHUB_INTEGRATION=true
FEATURE_SUPABASE_INTEGRATION=true
FEATURE_ZILLIZ_INTEGRATION=true
FEATURE_GEMINI_INTEGRATION=true

# ========================================
# RATE LIMITING PER ENDPOINT
# ========================================

# Search endpoints (read-heavy, more permissive)
SEARCH_RATE_LIMIT_PER_MINUTE=200

# Document creation (write-heavy, more restrictive)
CREATION_RATE_LIMIT_PER_MINUTE=10

# Authentication endpoints (very restrictive)
AUTH_RATE_LIMIT_PER_MINUTE=5

# ========================================
# EMAIL NOTIFICATIONS (Optional)
# ========================================

# SMTP Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Notification Settings
NOTIFICATION_EMAIL=admin@your-domain.com
ERROR_NOTIFICATION_EMAIL=devops@your-domain.com