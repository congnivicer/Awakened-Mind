{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Awakened Mind",
  "version": "0.1.0",
  "identifier": "com.awakened.mind",
  "build": {
    "frontendDist": "../dist/spa",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:client"
  },
  "app": {
    "windows": [
      {
        "title": "Awakened Mind",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
